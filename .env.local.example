# GitHub API — generate at https://github.com/settings/tokens
# Scope: public_repo (read-only)
# Increases rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Resend — get at https://resend.com (free tier: 100 emails/day)
# Used for the contact form
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Your production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://dhiaeddine.me
